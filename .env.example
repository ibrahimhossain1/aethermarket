# ==============================================================================
# Premium Digital Products Marketplace - Environment Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database (PostgreSQL - Supabase)
# ------------------------------------------------------------------------------
# Connection string with pooling (transaction mode, usually port 6543)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection string (session mode, usually port 5432) for running migrations
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------------------------
# 2. Authentication (NextAuth.js v5)
# ------------------------------------------------------------------------------
# Run `openssl rand -base64 33` to generate a secure secret
AUTH_SECRET="your_next_auth_secret_here"
# The base URL of the application
NEXTAUTH_URL="http://localhost:3000"

# Social Authentication Providers
AUTH_GOOGLE_ID="google_client_id_here"
AUTH_GOOGLE_SECRET="google_client_secret_here"
AUTH_GITHUB_ID="github_client_id_here"
AUTH_GITHUB_SECRET="github_client_secret_here"

# ------------------------------------------------------------------------------
# 3. File/Asset Storage (Supabase Storage)
# ------------------------------------------------------------------------------
SUPABASE_URL="https://[YOUR_PROJECT_ID].supabase.co"
# Service role key is required to generate secure 1-hour signed download URLs
SUPABASE_SERVICE_ROLE_KEY="supabase_service_role_key_here"
# The bucket name for private downloadable assets
SUPABASE_STORAGE_BUCKET="digital-assets"
# The bucket name for public preview images/screenshots
SUPABASE_PUBLIC_BUCKET="product-previews"

# ------------------------------------------------------------------------------
# 4. Payments (Stripe)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook secret generated by Stripe CLI or Dashboard for /api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."
# Stripe Connect settings for onboarding sellers
STRIPE_CONNECT_CLIENT_ID="ca_..."

# ------------------------------------------------------------------------------
# 5. Platform Configurations
# ------------------------------------------------------------------------------
# Platform commission fee (15% is 0.15)
PLATFORM_FEE_PERCENTAGE="0.15"

# ------------------------------------------------------------------------------
# 6. Transactional Emails (Resend)
# ------------------------------------------------------------------------------
RESEND_API_KEY="re_..."
# Email address from which transactional emails are sent
EMAIL_FROM="Marketplace <noreply@yourdomain.com>"
